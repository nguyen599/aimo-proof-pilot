# Copy to .env and fill in your credentials. .env is gitignored — never commit real values.
# Format: one KEY=VALUE per line (no quotes, no `export`); blank lines and # comments allowed.
# Loaded automatically by src/train.py (does not override already-exported variables)
# and sourced by the main OPD launch script (sourcing DOES override exported variables).
#
# Any other env var (repo URLs, PRIME_OPD_* launch inputs, WANDB_MODE, ...) can also be
# set here to override its default in src/train.py or operator_commands/*.sh — see README.

GITHUB_TOKEN=
HF_TOKEN=
WANDB_API_KEY=
# Optional: API-judge verifier paths.
OPENROUTER_API_KEY=
# Optional: s3:// uploads via upload.py.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
