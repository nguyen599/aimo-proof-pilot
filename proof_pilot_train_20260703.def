Bootstrap: docker
From: {{ BASE_IMAGE }}

%arguments
    BASE_IMAGE=chankhavu/aimo-proof-pilot:v4
    CUDA_VERSION=13.0.2

%environment
    export SUBMISSIONS_REPO=https://github.com/nguyen599/aimo-proof-pilot.git
    export SUBMISSIONS_REF=main
    export SUBMISSION_REPO=https://github.com/nguyen599/aimo-proof-pilot.git
    export SUBMISSION_REF=main
    export SUBMISSION_DIR=/workspace/aimo-proof-pilot
    export SUBMISSIONS_RUNTIME_DIR=/tmp/aimo-proof-pilot-runtime
    export OPEN_INSTRUCT_DIR=/opt/open-instruct
    export OLMO_CORE_DIR=/opt/OLMo-core
    export MEGATRON_CORE_DIR=/opt/Megatron-LM
    export PYTHONPATH=/app:/workspace/aimo-proof-pilot/src:/tmp/aimo-proof-pilot-runtime/src:/opt/open-instruct:/opt/OLMo-core/src:/opt/Megatron-LM
    export HF_HOME=/tmp/olmo_train_runtime_cache/hf
    export HUGGINGFACE_HUB_CACHE=/tmp/olmo_train_runtime_cache/hf
    export TRANSFORMERS_CACHE=/tmp/olmo_train_runtime_cache/hf
    export TORCH_HOME=/tmp/olmo_train_runtime_cache/torch
    export TORCHINDUCTOR_CACHE_DIR=/tmp/olmo_train_runtime_cache/torchinductor
    export TRITON_CACHE_DIR=/tmp/olmo_train_runtime_cache/triton
    export XDG_CACHE_HOME=/tmp/olmo_train_runtime_cache/xdg
    export FLASHINFER_CACHE_DIR=/tmp/olmo_train_runtime_cache/flashinfer
    export VLLM_CACHE_ROOT=/tmp/olmo_train_runtime_cache/vllm
    export WANDB_DIR=/tmp/olmo_train_runtime_cache/wandb
    export WANDB_CACHE_DIR=/tmp/olmo_train_runtime_cache/wandb_cache
    export WANDB_CONFIG_DIR=/tmp/olmo_train_runtime_cache/wandb_config
    export OLMO_RUNTIME_CACHE_ROOT=/tmp/olmo_train_runtime_cache
    export OLMO_OUTPUT_ROOT=/tmp/olmo_train_outputs
    export OLMO_LOG_ROOT=/tmp/olmo_train_logs
    export TMPDIR=/tmp
    export TMP=/tmp
    export TEMP=/tmp
    export GIT_LFS_SKIP_SMUDGE=1
    export SKIP_INSTALL_TRAINING_DEPS=1
    export USE_HUB_KERNELS=NO
    export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
    export TORCH_DIST_INIT_BARRIER=1
    export TORCH_NCCL_ASYNC_ERROR_HANDLING=1
    export TORCH_NCCL_AVOID_RECORD_STREAMS=1
    export NCCL_DEBUG=WARN
    export NCCL_NVLS_ENABLE=1
    export HTTPX_LOG_LEVEL=WARNING
    export OMP_NUM_THREADS=8
    export HF_XET_HIGH_PERFORMANCE=1
    export CUDA_VERSION={{ CUDA_VERSION }}
    export CUDNN_PATH=/usr/local/lib/python3.12/site-packages/nvidia/cudnn/include
    export CPLUS_INCLUDE_PATH=/usr/local/cuda/include:/usr/local/cuda/include/cccl:/usr/local/lib/python3.12/site-packages/nvidia/cuda_runtime/include:/usr/local/lib/python3.12/site-packages/nvidia/cudnn/include
    export CPATH=/usr/local/cuda/targets/x86_64-linux/include:/usr/local/cuda/include:/usr/local/lib/python3.12/site-packages/nvidia/cuda_runtime/include
    export CUDAToolkit_ROOT=/usr/local/cuda
    export CUDA_HOME=/usr/local/cuda
    export CUDA_PATH=/usr/local/cuda
    export CUDACXX=/usr/local/cuda/bin/nvcc
    export GDRCOPY_HOME=/root/gdrcopy
    export PATH=/usr/local/cuda/bin:/usr/local/nvidia/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LD_LIBRARY_PATH=/usr/local/cudnn/lib:/usr/local/cuda/lib64:/usr/local/ucx/lib:/opt/nvidia/nvda_nixl/lib/x86_64-linux-gnu:/opt/nvidia/nvda_nixl/lib64:/usr/lib/x86_64-linux-gnu:/usr/local/nvidia/lib:/usr/local/nvidia/lib64:${LD_LIBRARY_PATH}
    # Pass secrets at build/runtime via the environment; do not commit them.
    export HF_TOKEN="${HF_TOKEN:-}"
    export WANDB_API_KEY="${WANDB_API_KEY:-}"
    export GITHUB_TOKEN="${GITHUB_TOKEN:-}"


%post
    export DEBIAN_FRONTEND=noninteractive
    export GIT_LFS_SKIP_SMUDGE=1
    export SUBMISSION_REPO="${SIF_SUBMISSION_REPO:-https://github.com/nguyen599/aimo-proof-pilot.git}"
    export SUBMISSION_REF="${SIF_SUBMISSION_REF:-main}"
    export SUBMISSIONS_REPO="${SUBMISSION_REPO}"
    export SUBMISSIONS_REF="${SUBMISSION_REF}"
    export SUBMISSION_DIR="${SUBMISSION_DIR:-/workspace/aimo-proof-pilot}"

    apt-get update
    apt-get install -y --no-install-recommends ca-certificates git
    rm -rf /var/lib/apt/lists/*

    set +x
    if [ -n "${GITHUB_TOKEN:-}" ]; then
        git config --global url."https://${GITHUB_TOKEN}@github.com/".insteadOf "https://github.com/"
    fi
    set -x

    mkdir -p /app
    rm -rf "${SUBMISSION_DIR}"
    git clone --filter=blob:none "${SUBMISSION_REPO}" "${SUBMISSION_DIR}"
    cd "${SUBMISSION_DIR}"
    git fetch --depth 1 origin "${SUBMISSION_REF}" || true
    git checkout --force "${SUBMISSION_REF}" || git checkout --force FETCH_HEAD
    cp -a "${SUBMISSION_DIR}/src/." /app/
    if [ -d "${SUBMISSION_DIR}/remote-shell/daemon" ]; then
        mkdir -p /app/remote-shell
        rm -rf /app/remote-shell/daemon
        cp -a "${SUBMISSION_DIR}/remote-shell/daemon" /app/remote-shell/daemon
    fi
    git config --global --unset-all url."https://${GITHUB_TOKEN:-}@github.com/".insteadOf || true

    mkdir -p /tmp/olmo_train_runtime_cache/hf /tmp/olmo_train_runtime_cache/xdg /tmp/olmo_train_runtime_cache/torch /tmp/olmo_train_runtime_cache/torchinductor /tmp/olmo_train_runtime_cache/triton /tmp/olmo_train_runtime_cache/vllm
    cd /app
    chmod +x /app/*.sh || true
    if [ "${SKIP_INSTALL_TRAINING_DEPS:-1}" != "1" ]; then
        OLMO_CORE_REF="${OLMO_CORE_REF:-main}" \
        OPEN_INSTRUCT_REF="${OPEN_INSTRUCT_REF:-main}" \
        CUDA_VERSION="{{ CUDA_VERSION }}" \
        INSTALL_MODAL_SIMP_EXTRAS=1 \
        INSTALL_FULL_SYSTEM_APT="${INSTALL_FULL_SYSTEM_APT:-1}" \
        INSTALL_CONTAINER_BUILD_APT="${INSTALL_CONTAINER_BUILD_APT:-0}" \
        INSTALL_SINGULARITY_CE="${INSTALL_SINGULARITY_CE:-0}" \
        INSTALL_APPTAINER_IN_IMAGE="${INSTALL_APPTAINER_IN_IMAGE:-0}" \
        INSTALL_APEX="${INSTALL_APEX:-1}" \
        INSTALL_MEGATRON_CORE="${INSTALL_MEGATRON_CORE:-1}" \
        /app/install_training_deps.sh
    else
        echo "Skipping /app/install_training_deps.sh because SKIP_INSTALL_TRAINING_DEPS=${SKIP_INSTALL_TRAINING_DEPS:-1}."
    fi

    if ! command -v uv >/dev/null 2>&1; then
        python -m pip install --no-cache-dir --upgrade uv
    fi
    source /app/cuda_config.sh
    uv pip install --system --prerelease=allow --no-cache-dir \
        "verifiers[harbor]>=0.1.15.dev411" \
        "deep-gemm @ https://github.com/PrimeIntellect-ai/prime-rl/releases/download/v0.5.0/deep_gemm-2.5.0+891d57b-cp312-cp312-linux_x86_64.whl"
    uv pip uninstall --system kernels || true
    uv pip install --system --no-cache-dir --no-deps "${NVIDIA_NCCL_DIST}==2.29.3"
    if [ -f /app/remote-shell/daemon/requirements.txt ]; then
        uv pip install --system --no-cache-dir -r /app/remote-shell/daemon/requirements.txt
    fi

    set +x
    python - <<'PY'
import os
import shlex
from pathlib import Path

env_path = Path("/.singularity.d/env/95-proof-pilot-secrets.sh")
names = [
    "HF_TOKEN",
    "HUGGINGFACE_TOKEN",
    "GITHUB_TOKEN",
    "WANDB_API_KEY",
    "OPENAI_API_KEY",
    "OPENAI_BASE_URL",
    "OPENROUTER_API_KEY",
]
values = {name: os.environ.get(name, "") for name in names}
if values.get("HF_TOKEN") and not values.get("HUGGINGFACE_TOKEN"):
    values["HUGGINGFACE_TOKEN"] = values["HF_TOKEN"]

with env_path.open("w", encoding="utf-8") as handle:
    handle.write("# Baked runtime credentials for proof-pilot containers.\n")
    for name in names:
        value = values.get(name, "")
        if value:
            handle.write(f"export {name}={shlex.quote(value)}\n")
    handle.write('export POLL_INTERVAL="${POLL_INTERVAL:-5}"\n')
env_path.chmod(0o644)
PY
    set -x

    cat > /app/entrypoint.sh <<'EOF'
#!/bin/bash
set +e
trap '' TERM INT HUP PIPE QUIT
LOGS=/tmp/imochallenge/logs
LOG="$LOGS/relay-daemon.log"
mkdir -p "$LOGS" 2>/dev/null
announce() {
    printf '\n============================================================\n'
    printf '  REMOTE-SHELL DAEMON %s\n' "$1"
    printf '  client_id = %s\n' "${CLIENT_ID:-$(hostname 2>/dev/null)}"
    printf '  container runs until killed  |  logs: %s\n' "$LOG"
    printf '============================================================\n\n'
}
announce "STARTING"
if [ -f /app/smoke_test_opd.py ]; then
    /usr/bin/python /app/smoke_test_opd.py 2>&1 | tee -a "$LOG" || true
fi
while :; do
    announce "RUNNING (daemon (re)starting)"
    /usr/bin/python3 /app/remote-shell/daemon/client.py 2>&1 | tee -a "$LOG"
    printf '[supervisor %s] daemon exited - restart in 5s\n' "$(date -u '+%F %T' 2>/dev/null)" | tee -a "$LOG"
    sleep 5 2>/dev/null || true
done
EOF
    chmod +x /app/entrypoint.sh

    cat > /usr/local/bin/opd-run <<'EOF'
#!/bin/bash
set -euo pipefail
[ "$#" -ge 2 ] || { echo "usage: opd-run <name> <command...>" >&2; exit 2; }
name=$1
shift
run=/tmp/imochallenge/run
logs=/tmp/imochallenge/logs
mkdir -p "$run" "$logs"
log="$logs/$name.log"
pidf="$run/$name.pid"
if [ -f "$pidf" ] && kill -0 "$(cat "$pidf" 2>/dev/null || echo -1)" 2>/dev/null; then
    echo "opd-run: '$name' already running (pid $(cat "$pidf"))" >&2
    exit 1
fi
setsid bash -c 'echo "[opd-run start $(date -u)] $*"; "$@"; echo "[opd-run exit $? $(date -u)]"' _ "$@" >>"$log" 2>&1 &
echo $! >"$pidf"
echo "opd-run: '$name' started (pid $(cat "$pidf"))  log=$log"
EOF

    cat > /usr/local/bin/opd-status <<'EOF'
#!/bin/bash
run=/tmp/imochallenge/run
logs=/tmp/imochallenge/logs
shopt -s nullglob
if [ "$#" -ge 1 ]; then
    set -- "$1"
else
    set --
    for f in "$run"/*.pid; do
        set -- "$@" "$(basename "$f" .pid)"
    done
fi
[ "$#" -gt 0 ] || { echo "no runs under $run"; exit 0; }
for n in "$@"; do
    pidf="$run/$n.pid"
    log="$logs/$n.log"
    pid=$(cat "$pidf" 2>/dev/null || echo '?')
    if [ "$pid" != '?' ] && kill -0 "$pid" 2>/dev/null; then
        st=RUNNING
    else
        st=stopped
    fi
    printf '== %-20s [%s] pid=%s\n' "$n" "$st" "$pid"
    [ -f "$log" ] && tail -n 3 "$log" | sed 's/^/   /'
done
EOF
    chmod +x /usr/local/bin/opd-run /usr/local/bin/opd-status

%test
    set -eu
    export PYTHONDONTWRITEBYTECODE=1
    python - <<'PY'
import ast
from pathlib import Path

for path in [
    "/app/train.py",
    "/app/train_engine.py",
    "/app/train_engine_rl.py",
    "/app/train_engine_verl.py",
    "/app/proof_opd_env.py",
]:
    ast.parse(Path(path).read_text(), filename=path)
    print(f"{path} syntax OK")
PY
    python - <<'PY'
from importlib.metadata import PackageNotFoundError, version

import torch

print("proof pilot SIF OK")
print("torch", torch.__version__)
print("cuda", torch.version.cuda)
cuda_major = str(torch.version.cuda or "13").split(".", 1)[0]
for dist_name in [
    "vllm",
    "torchao",
    "transformer-engine",
    f"nvidia-nccl-cu{cuda_major}",
    "flashinfer-python",
    "flash-attn",
    "flash-attn-3",
    "ring-flash-attn",
    "verifiers",
    "deep-gemm",
]:
    try:
        print(dist_name, version(dist_name))
    except PackageNotFoundError:
        print(dist_name, "not installed")
for module_name in ["proof_opd_env", "deepseek_math_v2_env"]:
    __import__(module_name)
    print(module_name, "import OK")
import gradio_client
print("gradio_client import OK")
PY
    test -f /.singularity.d/env/95-proof-pilot-secrets.sh
    test -x /app/entrypoint.sh
    test -x /usr/local/bin/opd-run
    test -x /usr/local/bin/opd-status

%runscript
    if [ "${1:-}" = "launcher-dryrun" ] || [ "${1:-}" = "pbs-dryrun" ]; then
        shift
        exec python /app/train.py --dry_run_launch "$@"
    fi
    if [ "${1:-}" = "train" ]; then
        shift
        exec python /app/train.py "$@"
    fi
    if [ "$#" -gt 0 ] && [ "${1#-}" != "$1" ]; then
        exec python /app/train.py "$@"
    fi
    exec /app/entrypoint.sh "$@"
